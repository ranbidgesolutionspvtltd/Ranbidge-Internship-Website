# Environment Variables Example
# Copy this file to .env and fill in your actual values

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Deployment Configuration
NODE_ENV=production
PORT=3000

# Domain Configuration
DOMAIN=https://ranbidge.com

# Docker Configuration
DOCKER_REGISTRY=your-docker-username
IMAGE_NAME=ranbidge-website

# SSL Configuration (optional)
SSL_EMAIL=admin@ranbidge.com
SSL_DOMAINS=ranbidge.com,www.ranbidge.com

# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Social Media Links
GITHUB_URL=https://github.com/Rgopi143/RANBIDGE-INTERN
LINKEDIN_URL=https://linkedin.com/company/ranbidge-solutions
TWITTER_URL=https://twitter.com/ranbidge_solutions
